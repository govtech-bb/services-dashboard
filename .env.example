# Backend APIs
VITE_PROCESSING_API_URL=http://localhost:5500/api
VITE_ALPHA_PREVIEW_URL=http://localhost:3000

# Cognito — copy from your User Pool settings
# Authority: https://cognito-idp.{region}.amazonaws.com/{userPoolId}
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your_app_client_id
VITE_COGNITO_REDIRECT_URI=http://localhost:5173

# Used for the sign-out redirect to the Cognito Hosted UI
# Format: your-domain.auth.us-east-1.amazoncognito.com (no https://)
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
